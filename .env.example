# ─── Polymarket API Credentials ───────────────────────────────────────────────
# Generate at: https://docs.polymarket.com/#authentication
# These are the L2 API keys for order signing (not your wallet private key)
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_api_secret_here
POLYMARKET_API_PASSPHRASE=your_api_passphrase_here

# ─── Blockchain / Wallet ──────────────────────────────────────────────────────
# Session key private key (limited-scope key stored on VPS, NOT your main wallet)
# Generate a dedicated wallet for the bot and fund it minimally
PRIVATE_KEY=0xYOUR_BOT_SESSION_PRIVATE_KEY

# Your Gnosis Safe address on Polygon (holds the USDC treasury)
# Create at: https://app.safe.global/ on Polygon network
SAFE_ADDRESS=0xYOUR_SAFE_ADDRESS

# Polygon RPC (can use the public one or Alchemy/Infura for reliability)
POLYGON_RPC=https://polygon-rpc.com

# ─── Bot Capital ──────────────────────────────────────────────────────────────
# Total USDC the bot is authorized to use (must match what's in Safe)
BANKROLL_USDC=500.0

# ─── Redis (leave as-is for Docker Compose) ───────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
